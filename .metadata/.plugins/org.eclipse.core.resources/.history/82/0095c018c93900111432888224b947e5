package hamming;

import java.math.BigInteger;
import java.util.BitSet;

public class Hamming {
	private int control; // cantidad de bits de control
	private int lenght; //largo del mensaje resultante (informacion + controles) 
public Hamming(int lenght, int control) {
	this.control=control;
	this.lenght=lenght;
}
public BitSet hamming(BitSet string) {
	BitSet hamming = new BitSet(lenght);
	int j = 0;
	for(int i=0;i< lenght;i++) {
	  if( ((i + 1) & i) != 0 ) { // si la posicion es la de un bit de control lo calculo
		  hamming.set(i, string.get(j));
		  j++;
	  }}
	
	  for(int c=0;c<control;c++) {
	  boolean cont = false; 
	     int mask = 1 << c;
		 for(int h=mask-1; h<lenght;h++ ){		     
			if( ((h+1) & mask) != 0) { 
			 cont= string.get(h) ^ cont;
			 }
			}
		 hamming.set(mask, cont);
	    }
	
	return hamming; 
}
}
