	BitSet hamming = new BitSet(lenght);
	int j = 0;
	int c=0;
	for(int i=0;i<string.length();i++) {
	  if(((i + 1) & i) != 0) { // si la posicion es la de un bit de control lo calculo
		 boolean cont = false; 
		 int des = (int)Math.pow(2, c);
	     int mascara = (int) ((Math.pow(2, c)));
		 for(int h=des; h<lenght;h++ ){
			if((i+1)&mascara=mascara) { 
			 cont= string.get(h)^cont;
			 }
			}
		 hamming.set(i, cont);
	  }
	  else { // si es posicion de un bit de informacion copio 
		  hamming.set(i, string.get(j));
		  j++;
	  }
	}
	return null;
}
}
